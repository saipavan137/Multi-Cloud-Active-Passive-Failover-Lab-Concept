# Copy to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

project_name = "failover-lab"

# AWS-only mode (no Azure, no domain required):
enable_azure   = false
enable_route53 = false

# Uncomment below when you add Azure + a Route 53 domain later:
# enable_azure   = true
# enable_route53 = true
# domain_name    = "example.com"
# app_subdomain  = "app"
# create_hosted_zone = false
# hosted_zone_id     = "Z0123456789ABCDEFGHIJ"

# Regions (pick pairs close to each other for lower latency)
aws_region     = "us-east-1"
azure_location = "eastus"

# Small instances keep lab cost low (free-tier eligible where available)
aws_instance_type = "t3.micro"
azure_vm_size     = "Standard_B1s"

# Health check: 30s interval × 2 failures ≈ 60 seconds to failover
health_check_interval          = 30
health_check_failure_threshold = 2
