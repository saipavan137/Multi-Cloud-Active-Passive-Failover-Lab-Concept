# Example lab configuration — copy values into GitHub repository Variables
# (Settings → Secrets and variables → Actions → Variables)
# or use locally: terraform apply -var-file=config/lab.tfvars

project_name = "failover-lab"

enable_azure   = true
enable_route53 = true
enable_https   = false

domain_name        = "example.com"
app_subdomain      = "app"
create_hosted_zone = true
# hosted_zone_id   = "Z0123456789ABCDEFGHIJ"  # when create_hosted_zone = false

aws_region        = "us-east-1"
aws_instance_type = "t3.micro"

azure_location = "westus2"
azure_vm_size  = "Standard_D2s_v3"

health_check_interval          = 30
health_check_failure_threshold = 2
